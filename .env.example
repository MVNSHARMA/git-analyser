# ============================================================
# Git Analyser — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://dev:dev@postgres:5432/gitanalyser

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX

# --- GitHub OAuth ---
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=REPLACE_WITH_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_GITHUB_CLIENT_SECRET
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# --- Groq ---
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY

# --- Pinecone (vector DB) ---
PINECONE_API_KEY=REPLACE_WITH_PINECONE_API_KEY
PINECONE_INDEX=git-analyser

# --- Email (SMTP) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASS
SMTP_FROM=no-reply@gitanalyser.app

# --- App ---
APP_URL=http://localhost:3000
API_PORT=4000
NODE_ENV=development

# --- Encryption ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 32 bytes (64 hex chars) for AES-256
ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# --- Voyage AI ---
VOYAGE_API_KEY=REPLACE_WITH_VOYAGE_API_KEY

# --- Google Gemini ---
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
