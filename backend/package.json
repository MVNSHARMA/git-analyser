{
  "name": "git-analyser-backend",
  "version": "1.0.0",
  "description": "Git Analyser backend API",
  "main": "src/server.ts",
  "scripts": {
    "dev": "node -r dotenv/config dist/server.js",
    "build": "tsc --project tsconfig.dev.json --outDir dist",
    "start": "node -r dotenv/config dist/server.js",
    "migrate": "ts-node src/config/migrate.ts",
    "seed": "ts-node src/seed.ts",
    "worker": "node -r dotenv/config dist/jobs/queue-worker.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^3.0.0",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "groq-sdk": "^0.7.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "openai": "^4.52.3",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "voyageai": "^0.0.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.11",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^9.7.0",
    "jest": "^29.7.0",
    "madge": "^8.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}